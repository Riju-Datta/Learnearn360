# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/learnearn360"

# ─── NextAuth ────────────────────────────────────────────────────────────────
AUTH_SECRET="your-super-secret-key-min-32-chars-change-this"
AUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# GitHub OAuth (optional)
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PREMIUM_MONTHLY_PRICE_ID="price_..."
STRIPE_PREMIUM_ANNUAL_PRICE_ID="price_..."
STRIPE_LIFETIME_PRICE_ID="price_..."

# ─── Resend (Email) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="LearnEarn 360 <noreply@learnearn360.com>"

# ─── UploadThing ─────────────────────────────────────────────────────────────
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="your-app-id"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Redis (optional, for rate limiting) ─────────────────────────────────────
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# ─── Cron Jobs ───────────────────────────────────────────────────────────────
# Shared secret to authorize scheduled job requests (e.g. Vercel Cron)
CRON_SECRET="generate-a-random-secret-here"

# ─── Socket.io (real-time features) ──────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
SOCKET_PORT=3001
